{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/business-license/layout,_N_T_/[locale]/business-license/page,_N_T_/fr/business-license"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/business-license/__PAGE__",
    "/$d$locale/business-license",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}
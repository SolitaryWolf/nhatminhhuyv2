{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/services/layout,_N_T_/[locale]/services/inland-transport/layout,_N_T_/[locale]/services/inland-transport/page,_N_T_/fr/services/inland-transport"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/services/inland-transport/__PAGE__",
    "/$d$locale/services/inland-transport",
    "/$d$locale/services",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}
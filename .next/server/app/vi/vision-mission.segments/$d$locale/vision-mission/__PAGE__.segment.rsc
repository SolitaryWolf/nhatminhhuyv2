0:{"rsc":["$","$1","c",{"children":[["$","$L2",null,{"locale":"vi","backgroundImage":"/images/Dịch vụ chuyển máy CNC.jpg","activePage":"vision-mission","children":[["$","h1",null,{"className":"text-xl font-bold bg-gradient-to-r from-[#1F5F9E] to-[#FFD900] bg-clip-text text-transparent mb-8 leading-tight py-2","children":"TẦM NHÌN & SỨ MỆNH"}],["$","div",null,{"className":"space-y-8","children":[["$","section",null,{"className":"glass-card p-8","children":[["$","h2",null,{"className":"text-3xl font-bold bg-gradient-to-r from-[#ff6b35] to-[#ffa500] bg-clip-text text-transparent mb-4","children":"Tầm nhìn"}],["$","p",null,{"className":"text-gray-800 leading-relaxed text-lg","children":"Tương lai Việt Nam sẽ là trung tâm của hội nhập, sản xuất, tham gia sâu rộng vào chuỗi cung ứng toàn cầu. Xây dựng Nhật Minh Huy trở thành một trong những Doanh Nghiệp cung cấp giải pháp logistics hàng đầu tại Việt Nam nhằm mang đến cho Khách Hàng những dịch vụ chất lượng với chi phí tối ưu."}]]}],["$","section",null,{"className":"glass-card p-8","children":[["$","h2",null,{"className":"text-3xl font-bold bg-gradient-to-r from-[#ff6b35] to-[#ffa500] bg-clip-text text-transparent mb-4","children":"Sứ mệnh"}],["$","p",null,{"className":"text-gray-800 leading-relaxed text-lg","children":"Hoạt động trên lãnh thổ Việt Nam còn nhiều khó khăn, thách thức nhưng NHẬT MINH HUY cảm nhận được cơ hội vươn ra toàn cầu của nền kinh tế nước nhà. Doanh nghiệp Việt Nam cần cánh tay nối dài ra thị trường quốc tế. Chúng tôi không đặt lợi nhuận là mục tiêu hàng đầu, hơn hết phải là đào tạo được đội ngũ tinh nhuệ nhất giúp được nhiều khách hàng nhất vươn mình ra biển lớn."}]]}]]}]]}],[["$","script","script-0",{"src":"/_next/static/chunks/0p5o_ih~~~6yt.js","async":true}]],["$","$L3",null,{"children":["$","$4",null,{"name":"Next.MetadataOutlet","children":"$@5"}]}]]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"1vjYS1PtVbBsRA7ajChNB"}

{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/services/layout,_N_T_/[locale]/services/vehicle-rental/layout,_N_T_/[locale]/services/vehicle-rental/page,_N_T_/vi/services/vehicle-rental"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/services/vehicle-rental/__PAGE__",
    "/$d$locale/services/vehicle-rental",
    "/$d$locale/services",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}
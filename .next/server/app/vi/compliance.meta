{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/compliance/layout,_N_T_/[locale]/compliance/page,_N_T_/vi/compliance"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/compliance/__PAGE__",
    "/$d$locale/compliance",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}
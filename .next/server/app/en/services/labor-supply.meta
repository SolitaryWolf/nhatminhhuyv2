{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/services/layout,_N_T_/[locale]/services/labor-supply/layout,_N_T_/[locale]/services/labor-supply/page,_N_T_/en/services/labor-supply"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/services/labor-supply/__PAGE__",
    "/$d$locale/services/labor-supply",
    "/$d$locale/services",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}
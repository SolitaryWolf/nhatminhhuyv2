{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/vision-mission/layout,_N_T_/[locale]/vision-mission/page,_N_T_/en/vision-mission"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/vision-mission/__PAGE__",
    "/$d$locale/vision-mission",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}
{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/partners/layout,_N_T_/[locale]/partners/page,_N_T_/de/partners"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/partners/__PAGE__",
    "/$d$locale/partners",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}
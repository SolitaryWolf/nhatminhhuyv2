{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/services/layout,_N_T_/[locale]/services/lifting-installation/layout,_N_T_/[locale]/services/lifting-installation/page,_N_T_/de/services/lifting-installation"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/services/lifting-installation/__PAGE__",
    "/$d$locale/services/lifting-installation",
    "/$d$locale/services",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}